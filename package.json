{
  "name": "@buley/hexgrid-3d",
  "version": "3.6.1",
  "description": "3D hexagonal grid visualization component for React",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/buley/hexgrid-3d.git"
  },
  "author": "buley",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "import": "./dist/stores/index.js",
      "default": "./dist/stores/index.js"
    },
    "./algorithms": {
      "types": "./dist/algorithms/index.d.ts",
      "import": "./dist/algorithms/index.js",
      "default": "./dist/algorithms/index.js"
    }
  },
  "scripts": {
    "build:shaders": "bun run scripts/build-shaders.ts",
    "prebuild": "bun run build:shaders",
    "build": "tsc -p tsconfig.build.json",
    "lint:wgsl": "bun run scripts/build-shaders.ts",
    "dev": "tsc --watch",
    "test": "bun test --timeout 30000",
    "test:watch": "bun test --timeout 30000 --watch",
    "test:coverage": "bun test --timeout 30000 --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "3d",
    "visualization",
    "hexgrid",
    "hexagonal",
    "grid",
    "sphere",
    "react",
    "canvas",
    "webgl",
    "three"
  ],
  "peerDependencies": {
    "next": "^14.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@a0n/aeon-3d": "workspace:*",
    "@webgpu/types": "^0.1.69",
    "@a0n/happy": "workspace:*",
    "@a0n/test-dom": "workspace:*"
  }
}
